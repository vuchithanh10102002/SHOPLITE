NODE_ENV=test
PORT=3001

# DB rieng cho test — setup.ts XOA SACH du lieu moi test, khong duoc tro vao DB dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoplite_test

# Redis db index 1 — tach khoi db 0 cua dev (rate limit + BullMQ khong dam nhau)
REDIS_URL=redis://localhost:6379/1

JWT_ACCESS_SECRET=test_access_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=test_refresh_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# cost 4 thay vi 12: bcrypt cost 12 lam suite test cham gap ~10 lan
BCRYPT_COST=4

CLIENT_URL=http://localhost:5173
CLOUDINARY_URL=cloudinary://test:test@test
SMTP_URL=smtp://test:test@localhost:1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=ShopLite Test <no-reply@test.local>
PAYMENT_FAIL_RATE=0
